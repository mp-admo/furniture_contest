<section class="hero">

    <div class="container">

        <div class="hero__content">

            <span class="hero__subtitle">
                Woodara Indonesian Design Contest 2026
            </span>

             <h1 class="hero__title">
                Dari Indonesia, <br />
                <span class="hero__title--italic">Untuk Dunia.</span>
            </h1>

            <p class="hero__description">
                Kompetisi desain mebel pertama yang membawa karya terbaik Indonesia langsung ke pasar global.
            </p>

        </div>

    </div>

</section>

<style>

    .hero {
        position: relative;
        background-color: #FFFFFF;
        width: 100%;
        height: calc(100vh - 6.4rem);
        display: flex;
        align-items: flex-end;
        overflow: hidden;
    }

    .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: url("/hero_image.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 1;
    }

    .container {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 140rem; 
        padding: 0 2rem;
        margin: 0 auto;
    }

    .hero__content {
        display: flex;
        flex-direction: column;
        max-width: 90rem;
        margin-bottom: 6rem;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
    }

    .hero__subtitle {
        display: inline-flex;
        align-items: center;
        color: #111; 
        font-size: 1.2rem; 
        font-weight: 500;
        letter-spacing: 0.2rem;
        text-transform: uppercase; 
        margin-bottom: 2rem; 
    }

      .hero__subtitle::before {
        content: ""; 
        display: inline-block;
        width: 0.6rem; 
        height: 0.6rem; 
        background-color: #111;
        border-radius: 50%; 
        margin-right: 1rem; 
    }

    .hero__title { 
        color: #111;
        margin-bottom: 3.2rem; 
    }

    .hero__title--italic {
        font-style: italic; 
        font-weight: 300;
        color: #888;
    }

    .hero__description {
        color: #111; 
        font-size: 1.5rem; 
        font-weight: 400; 
        line-height: 1.6; 
        max-width: 48rem; 
    }

</style>