<style>

    .showcase {
        background-color: #111;
        margin-bottom: 8rem;
    }

    .container {
        width: 100%;
        max-width: 140rem; 
        padding: 0 2rem;
        margin: 0 auto;
        border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
        border-right: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .showcase__countdown-wrapper {
        background-color: #171717;
        border-bottom: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .showcase__countdown {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2.8rem 0;
    }

    .showcase__countdown-text { 
        color: #888888;
        font-size: 1.1rem;
        letter-spacing: 0.2rem;
        text-transform: uppercase;
    }

    .showcase__timer {
        display: flex;
    }

    .showcase__time-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 12rem;
        padding: 0 3.6rem;
        border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
        gap: 0.6rem;
    }

    .showcase__time-value {
        color: #FFFFFF;
        font-size: 5.8rem;
        font-weight: 200;
        line-height: 1;
        letter-spacing: -0.04rem;
        font-variant-numeric: tabular-nums;
    }

    .showcase__time-label {
        color: #888;
        font-size: 0.9rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: 0.2rem;
        text-transform: uppercase;  
    }

    .showcase__metrics {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
    }

    .showcase__metric {
        display: flex;
        flex-direction: column;
        padding: 4.8rem;
        border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
        gap: 0.8rem;
    }

    .showcase__metric:first-child {
        border-left: none;
    }

    .showcase__metric-value {
        color: #FFFFFF;
        font-weight: 200;
        line-height: 1;
        letter-spacing: -0.04em;
        font-variant-numeric: tabular-nums;
    }

    .showcase__metric-label {
        color: #888888;
        font-size: 1.1rem;
        letter-spacing: 0.2rem;
        text-transform: uppercase; 
    }

    .showcase__ticker-wrapper {
        background-color: #171717;
        border-bottom: 0.1rem solid rgba(255, 255, 255, 0.1);
        border-top: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .showcase__ticker-wrapper .container {
        padding: 0;
    }

    .showcase__ticker {
        overflow: hidden;
    }

    .showcase__ticker-track {
        display: flex;
        align-items: center;
        width: max-content;
        padding: 1.6rem 0;
    }

    .showcase__ticker-item {
        color: #888888;
        font-size: 1rem;
        letter-spacing: 0.26rem;
        text-transform: uppercase;
        padding: 0 4rem;
        border-right: 0.1rem solid rgba(255, 255, 255, 0.1);
        white-space: nowrap;
    }

    .showcase__ticker-item:first-child {
        border-left: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .showcase__ticker-track {
        animation: ticker-scroll 40s linear infinite;
    }

    @keyframes ticker-scroll {

        from {
            transform: translateX(0);
        }

        to {
            transform: translateX(-50%);
        }

    }
    

    










</style>