<section class="cta">

    <div class="container">


        <!-- content -->
        <div class="cta__content">


            <!-- subtitle -->
            <span class="cta__subtitle">
                Bergabunglah Sekarang
            </span>


            <!-- title -->
            <h3 class="cta__title">

                Jangan Biarkan Keraguan

                <span class="cta__title-italic">
                    Membunuh Potensi Anda.
                </span>

            </h3>


            <!-- description -->
            <p class="cta__description">
                Syarat dan ketentuan lengkap akan segera kami rilis. Ikuti kami, persiapkan karya terbaik Anda, dan ubah takdir desain Anda hari ini.
            </p>


            <!-- actions -->
            <div class="cta__actions">


                <!-- main button -->
                <a 
                    href="https://www.woodara.online"
                    target="_blank"
                    class="cta__button"
                >

                <img 
                    src="/flag_icon.png"
                    alt="Indonesia Flag"
                    class="cta__button-flag"
                >

                Kunjungi Woodara

                </a>


                <!-- email -->
                <a 
                    href="mailto:woodara.shop@gmail.com"
                    class="cta__email"
                >
                    woodara.shop@gmail.com
                </a>

            </div>

        </div>

    </div>

</section>

<style>

    .cta {
        background-color: #171717;
        border-top: 0.1rem solid rgba(255, 255, 255, 0.1);
        padding: 9rem 0;
    }

    .cta .container {
        width: 100%;
        max-width: 140rem;
        padding: 0 2rem;
        margin: 0 auto;
    }

    .cta__content {
        max-width: 72rem;
        margin: 0 auto;
        text-align: center;
    }

    .cta__subtitle {
        display: inline-flex;
        align-items: center;
        color: #888888; 
        font-size: 1.2rem; 
        font-weight: 400;
        letter-spacing: 0.2rem;
        text-transform: uppercase;
        margin-bottom: 3.2rem;
    }

    .cta__subtitle::before {
        content: ""; 
        display: inline-block;
        width: 0.6rem; 
        height: 0.6rem; 
        background-color: #888888;
        border-radius: 50%; 
        margin-right: 1rem;
    }

    .cta__title {
        display: flex;
        flex-direction: column;
        color: #FFFFFF;
        font-size: clamp(4.2rem, 5vw, 5.4rem);
        font-weight: 300;
        line-height: 1.12;
        letter-spacing: -0.04em;
        margin-bottom: 2rem;
    }

    .cta__title-italic {
        font-style: italic;
        font-weight: 300;
        color: #888;
    }

    .cta__description {
        color: #888888;
        font-size: 1.6rem;
        line-height: 1.7;
        max-width: 58rem;
        margin: 0 auto 4rem auto;
    }

    .cta__actions {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.6rem;
    }

    .cta__button {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.6rem;
        border-radius: 18rem;
        background-color: #FFFFFF;
        color: #333;
        text-decoration: none;
        transition:
            transform 0.3s ease,
            opacity 0.3s ease;
    }


    .cta__button:hover {
        transform: translateY(-0.2rem);
        opacity: 0.9;
    }


    .cta__button-flag {
        width: 1.6rem;
        height: 1.6rem;
        object-fit: cover;
        border-radius: 50%;
    }

    .cta__email {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 1.6rem;
        border: 0.1rem solid rgba(255, 255, 255, 0.1);
        border-radius: 18rem;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        transition:
            border-color 0.3s ease,
            color 0.3s ease,
            background-color 0.3s ease;
    }

    .cta__email:hover {
        border-color: rgba(255, 255, 255, 0.2);
        color: #FFFFFF;
        background-color: rgba(255, 255, 255, 0.02);
    }

    @media (max-width: 768px) {
        
        .cta {
            padding: 6rem 0; 
        }

        .cta__content {
            max-width: 100%;
        }

        .cta__subtitle {
            margin-bottom: 2.4rem; 
        }

        .cta__title {
            font-size: 3.2rem; 
            line-height: 1.2;
            margin-bottom: 2.4rem;
        }

        .cta__title-italic {
            color: #888888; 
        }

        .cta__description {
            font-size: 1.4rem;
            line-height: 1.6;
            max-width: 100%;
            margin: 0 auto 3.2rem auto; 
        }

        .cta__actions {
            flex-direction: column; 
            align-items: center; 
            gap: 1.4rem;
            width: 100%;
        }

        .cta__button,
        .cta__email {
            width: 100%;
            max-width: 28rem;
            justify-content: center; 
        }

        .cta__button:hover {
            transform: none;
            opacity: 1;
        }

        .cta__email:hover {
            border-color: rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.5);
            background-color: transparent;
        }
    }

</style>